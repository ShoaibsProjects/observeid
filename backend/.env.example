# ─── ObserveID Backend — Environment Variables ─────────────
# Copy to .env and fill in values for local development.
# In production, these are set via Fly.io secrets or CI/CD secrets.
#
# NEVER commit .env to version control.

# ─── Database (PostgreSQL) ───────────────────────────────
# Local docker-compose:
DATABASE_URL=postgresql://observeid:observeid@localhost:5432/observeid?sslmode=disable
# Neon (cloud):
# DATABASE_URL=postgresql://<user>:<password>@ep-xxx.region.aws.neon.tech/observeid?sslmode=require

# ─── Neo4j ───────────────────────────────────────────────
# Local docker-compose:
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-local-neo4j-password>
# AuraDB (cloud):
# NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=<your-aura-password>

# ─── Redis ───────────────────────────────────────────────
# Local docker-compose:
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
# Upstash (cloud):
# REDIS_ADDR=xxx.upstash.io:6379
# REDIS_PASSWORD=<your-upstash-token>
# REDIS_TLS=true

# ─── Temporal ────────────────────────────────────────────
# Local docker-compose:
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=critical-offboarding
# Temporal Cloud:
# TEMPORAL_HOST=xxx.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=<your-namespace>

# ─── CORS ────────────────────────────────────────────────
# Set to the frontend URL in production (e.g., https://observeid.pages.dev)
CORS_ORIGIN=

# ─── Security ────────────────────────────────────────────
# API key auth (format: role:key,comma-separated)
API_KEYS=
# Vault encryption key — generate with: openssl rand -hex 32
VAULT_MASTER_KEY=<generate-with-openssl-rand-hex-32>
# Vault file path for local secrets
VAULT_PATH=./vault.json

# ─── TLS (optional, for local dev) ──────────────────────
TLS_CERT_FILE=
TLS_KEY_FILE=

# ─── Frontend (optional, for embedded static files) ─────
FRONTEND_DIR=
